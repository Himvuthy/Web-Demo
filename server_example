# --- DASHBOARD STATS ROUTE ---

@app.route('/api/admin/stats', methods=['GET'])

def get_admin_stats():

    try:

        conn = pyodbc.connect(conn_str)

        cursor = conn.cursor()

       

        cursor.execute("SELECT COUNT(*) FROM Students")

        total_students = cursor.fetchone()[0]

       

        return jsonify({

            "success": True,

            "totalStudents": total_students,

            "classes": "null",      

            "present": "null",    

            "absent": "null"      

        })

           

    except Exception as e:

        print(f"🚨 ADMIN STATS DB ERROR: {e}")

        return jsonify({"success": False, "error": str(e)}), 500

    finally:

        if 'conn' in locals():

            conn.close()



# --- FETCH ALL USERS ---

@app.route('/api/users', methods=['GET'])
def get_users():
    try:
        conn = pyodbc.connect(conn_str)
        cursor = conn.cursor()
        # Pulling the exact columns from your screenshot
        cursor.execute("SELECT UserID, Username, Role, StudentID, Gmail FROM Users")
        rows = cursor.fetchall()
        users_list = []
        for row in rows:
            users_list.append({
                "id": row[0],
                "name": row[1],
                "role": row[2],
                # Safely handling NULL values so React doesn't break
                "student_id": row[3] if row[3] is not None else "",
                "email": row[4] if row[4] is not None else "",
                "fingerprint_enrolled": False # Placeholder for hardware integration
            })
        return jsonify({"success": True, "users": users_list}), 200
    except Exception as e:
        print(f"🚨 GET USERS ERROR: {e}")
        return jsonify({"success": False, "error": str(e)}), 500
    finally:
        if 'conn' in locals():
            conn.close()



# --- EDIT USER ---

@app.route('/api/users/<int:user_id>', methods=['PUT'])

def edit_user(user_id):

    try:

        data = request.get_json()

        new_name = data.get('name')

        new_role = data.get('role')

       

        conn = pyodbc.connect(conn_str)

        cursor = conn.cursor()

       

        cursor.execute("UPDATE Users SET Username = ?, Role = ? WHERE UserID = ?", (new_name, new_role, user_id))

        conn.commit()

       

        return jsonify({"success": True, "message": "User updated successfully"}), 200

       

    except Exception as e:

        print(f"🚨 EDIT USER ERROR: {e}")

        return jsonify({"success": False, "error": str(e)}), 500

    finally:

        if 'conn' in locals():

            conn.close()



